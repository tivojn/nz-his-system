generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("doctor") // admin, doctor, nurse, receptionist, pharmacist, lab-tech, radiologist
  department    String?
  hpiNumber     String?   // Health Practitioner Index
  speciality    String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  notes         ClinicalNote[]
  appointments  Appointment[]
  auditLogs     AuditLog[]
  medications   Medication[]  @relation("PrescribedBy")
  labOrders     LabOrder[]    @relation("OrderedBy")
  referrals     Referral[]    @relation("ReferredBy")
  incidentReports IncidentReport[] @relation("ReportedBy")
}

model Patient {
  id            String    @id @default(cuid())
  nhiNumber     String    @unique // National Health Index
  firstName     String
  lastName      String
  dateOfBirth   DateTime
  gender        String
  ethnicity     String    // European, Maori, Pacific Islander, Asian, Other
  iwi           String?   // Maori tribal affiliation
  phone         String?
  email         String?
  address       String?
  city          String?
  region        String?
  emergencyContact String?
  emergencyPhone   String?
  accClaimNumber   String? // ACC claim
  accClaimStatus   String? // active, closed, pending
  bloodType     String?   // A+, A-, B+, B-, AB+, AB-, O+, O-
  status        String    @default("active") // active, discharged, deceased
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  notes         ClinicalNote[]
  encounters    Encounter[]
  appointments  Appointment[]
  waitlistEntries WaitlistEntry[]
  observations  Observation[]
  medications   Medication[]
  clinicalAlerts ClinicalAlert[]
  vitalSignSets VitalSignSet[]
  accClaims     ACCClaim[]
  bed           Bed?      @relation("PatientBed")
  allergies     Allergy[]
  labOrders     LabOrder[]
  referralsFrom Referral[] @relation("ReferralPatient")
  incidentReports IncidentReport[] @relation("IncidentPatient")
}

model Encounter {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  type          String    // admission, discharge, transfer, outpatient
  status        String    @default("in-progress") // planned, in-progress, finished, cancelled
  department    String?
  admitDate     DateTime  @default(now())
  dischargeDate DateTime?
  diagnosis     String?
  diagnosisCode String?   // SNOMED CT code
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ClinicalNote {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  authorId      String
  author        User      @relation(fields: [authorId], references: [id])
  type          String    @default("soap") // soap, progress, discharge, ai-generated, admission, surgical
  subjective    String?
  objective     String?
  assessment    String?
  plan          String?
  content       String?   // For non-SOAP notes
  diagnosisCode String?
  aiGenerated   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  providerId    String?
  provider      User?     @relation(fields: [providerId], references: [id])
  dateTime      DateTime
  duration      Int       @default(30) // minutes
  type          String    // consultation, follow-up, procedure, surgery
  department    String?
  status        String    @default("scheduled") // scheduled, completed, cancelled, no-show
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WaitlistEntry {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  department    String
  priority      String    @default("routine") // urgent, semi-urgent, routine
  procedure     String?
  referralDate  DateTime  @default(now())
  targetDate    DateTime?
  status        String    @default("waiting") // waiting, scheduled, completed, cancelled
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Observation {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  type          String    // vital-signs, lab-result, imaging
  code          String    // LOINC or local code
  codeName      String    // Human readable name
  value         String
  unit          String?
  referenceRange String?  // e.g., "4.0-11.0"
  interpretation String?  // normal, abnormal, critical
  status        String    @default("final") // preliminary, final, amended
  effectiveDate DateTime  @default(now())
  createdAt     DateTime  @default(now())
}

// ==================== MEDICATIONS ====================

model Medication {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  prescriberId  String
  prescriber    User      @relation("PrescribedBy", fields: [prescriberId], references: [id])
  name          String
  genericName   String?
  dose          String
  unit          String
  route         String    @default("oral") // oral, iv, im, sc, topical, inhaled
  frequency     String    // e.g. "BD", "TDS", "PRN", "STAT"
  status        String    @default("ordered") // ordered, verified, dispensed, administered, discontinued
  startDate     DateTime  @default(now())
  endDate       DateTime?
  instructions  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DrugInteraction {
  id            String    @id @default(cuid())
  drugA         String
  drugB         String
  severity      String    // critical, major, moderate, minor
  description   String
  recommendation String
  createdAt     DateTime  @default(now())
}

// ==================== CLINICAL SUPPORT ====================

model ClinicalAlert {
  id            String    @id @default(cuid())
  patientId     String?
  patient       Patient?  @relation(fields: [patientId], references: [id])
  type          String    // drug-interaction, lab-critical, fall-risk, sepsis, allergy, pathway
  severity      String    // critical, warning, info
  title         String
  message       String
  source        String?   // CDSS, Lab, Nursing, Pharmacy
  status        String    @default("active") // active, acknowledged, resolved
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ClinicalPathway {
  id            String    @id @default(cuid())
  name          String
  code          String    @unique
  description   String
  category      String    // cardiac, sepsis, ortho, endocrine
  steps         String    // JSON string of pathway steps
  expectedDuration String? // e.g. "4 hours", "72 hours"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VitalSignSet {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  heartRate       Int?
  systolicBP      Int?
  diastolicBP     Int?
  respiratoryRate Int?
  temperature     Float?
  oxygenSat       Int?
  consciousness   String?   // A, V, P, U (AVPU scale)
  painScore       Int?      // 0-10
  news2Score      Int?      // National Early Warning Score 2
  recordedBy      String?
  recordedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
}

// ==================== ACC CLAIMS ====================

model ACCClaim {
  id              String    @id @default(cuid())
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  claimNumber     String    @unique
  injuryDate      DateTime
  injuryDescription String
  injuryCode      String?   // Read code / ACC code
  claimType       String    // work, motor-vehicle, sport, home, assault
  status          String    @default("lodged") // lodged, accepted, declined, closed, review
  totalCost       Float     @default(0)
  events          ACCClaimEvent[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ACCClaimEvent {
  id            String    @id @default(cuid())
  claimId       String
  claim         ACCClaim  @relation(fields: [claimId], references: [id])
  type          String    // lodged, assessment, treatment, review, payment, closed
  description   String
  cost          Float     @default(0)
  eventDate     DateTime  @default(now())
  createdAt     DateTime  @default(now())
}

// ==================== BED MANAGEMENT ====================

model Bed {
  id            String    @id @default(cuid())
  ward          String    // e.g. "Medical Ward 1", "ICU", "Surgical Ward"
  bedNumber     String
  status        String    @default("available") // available, occupied, cleaning, maintenance
  patientId     String?   @unique
  patient       Patient?  @relation("PatientBed", fields: [patientId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([ward, bedNumber])
}

// ==================== AUDIT ====================

model AuditLog {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  action        String    // CREATE, READ, UPDATE, DELETE, LOGIN, LOGOUT, PRESCRIBE, DISCHARGE
  entity        String    // Patient, Encounter, Note, Medication, etc.
  entityId      String?
  severity      String    @default("info") // info, warning, critical
  details       String?   // JSON string with additional context
  ipAddress     String?
  createdAt     DateTime  @default(now())
}

// ==================== NEW MODELS — ALLERGIES ====================

model Allergy {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  allergen      String    // e.g., "Penicillin", "Latex", "Peanuts"
  type          String    // drug, food, environmental, other
  severity      String    // mild, moderate, severe, life-threatening
  reaction      String    // e.g., "Anaphylaxis", "Rash", "Nausea"
  status        String    @default("active") // active, inactive, resolved
  onsetDate     DateTime?
  verifiedBy    String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==================== NEW MODELS — LAB ORDERS ====================

model LabOrder {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id])
  orderedById   String
  orderedBy     User      @relation("OrderedBy", fields: [orderedById], references: [id])
  orderNumber   String    @unique
  testName      String    // e.g., "Full Blood Count", "Liver Function Tests"
  testCode      String    // LOINC code
  priority      String    @default("routine") // stat, urgent, routine
  status        String    @default("ordered") // ordered, collected, in-progress, completed, cancelled
  specimen      String?   // blood, urine, csf, swab, tissue
  clinicalNotes String?
  resultValue   String?
  resultUnit    String?
  referenceRange String?
  interpretation String?  // normal, abnormal, critical
  resultNotes   String?
  orderedAt     DateTime  @default(now())
  collectedAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ==================== NEW MODELS — REFERRALS ====================

model Referral {
  id               String    @id @default(cuid())
  patientId        String
  patient          Patient   @relation("ReferralPatient", fields: [patientId], references: [id])
  referredById     String
  referredBy       User      @relation("ReferredBy", fields: [referredById], references: [id])
  referralNumber   String    @unique
  fromDepartment   String
  toDepartment     String
  priority         String    @default("routine") // stat, urgent, routine
  status           String    @default("pending") // pending, accepted, declined, completed, cancelled
  reason           String
  clinicalSummary  String?
  responseNotes    String?
  requestedDate    DateTime  @default(now())
  acceptedDate     DateTime?
  completedDate    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ==================== NEW MODELS — INCIDENT REPORTS ====================

model IncidentReport {
  id              String    @id @default(cuid())
  patientId       String?
  patient         Patient?  @relation("IncidentPatient", fields: [patientId], references: [id])
  reportedById    String
  reportedBy      User      @relation("ReportedBy", fields: [reportedById], references: [id])
  incidentNumber  String    @unique
  type            String    // fall, medication-error, adverse-reaction, equipment-failure, near-miss, other
  severity        String    // none, minor, moderate, major, catastrophic
  location        String
  dateTime        DateTime
  description     String
  immediateAction String?
  rootCause       String?
  status          String    @default("reported") // reported, investigating, resolved, closed
  outcome         String?
  preventiveMeasures String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
